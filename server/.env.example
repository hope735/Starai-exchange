# =============================================================================
# StarAI Exchange — Backend (Express + MySQL) environment variables
# Copy this file to `server/.env` and fill in real values.
# Loaded via `import 'dotenv/config'` in server/src/db.ts & db-migrate.ts.
# =============================================================================

# --- MySQL connection ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=starai_exchange

# --- TLS / SSL ---
# Set to `true` for hosted MySQL providers (TiDB Cloud, PlanetScale, AWS RDS,
# Google Cloud SQL, Azure Database for MySQL) — they REQUIRE encrypted
# connections. Leave `false` for a local MySQL install.
#
# For most providers the default trust store is fine; if your provider gives
# you a CA bundle, paste its full contents (PEM) into DB_SSL_CA.
DB_SSL=false
# DB_SSL_CA=

# --- HTTP server ---
PORT=4000
CORS_ORIGIN=http://localhost:5173
