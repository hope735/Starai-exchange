# =============================================================================
# StarAI Exchange — Frontend environment variables (Vite)
# Copy this file to `.env` and fill in real values.
# All variables exposed to the browser MUST be prefixed with VITE_.
# =============================================================================

# CoinGecko public API base URL.
# Free tier: https://api.coingecko.com/api/v3
# Pro tier:  https://pro-api.coingecko.com/api/v3
VITE_COINGECKO_API=https://api.coingecko.com/api/v3

# Optional CoinGecko Demo / Pro API key.
# Sent as the `x-cg-demo-api-key` header from src/lib/api.ts.
# Leave blank to use the unauthenticated free tier (rate-limited).
VITE_COINGECKO_API_KEY=

# Backend API base URL the frontend will call.
# Defaults to http://localhost:4000/api when unset.
VITE_API_BASE_URL=http://localhost:4000/api
