# =============================================================================
# StarAI Exchange — Backend (Express + MySQL) environment variables
# Copy this file to `server/.env` and fill in real values.
# Loaded via `import 'dotenv/config'` in server/src/index.ts & db.ts.
# =============================================================================

# --- MySQL connection ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=starai_exchange

# --- TLS / SSL ---
# Set to `true` for hosted MySQL providers (TiDB Cloud, PlanetScale, AWS RDS,
# Google Cloud SQL, Azure Database for MySQL) — they REQUIRE encrypted
# connections. Leave `false` for a local MySQL install.
DB_SSL=false
# DB_SSL_CA=

# --- HTTP server ---
PORT=4000

# --- CORS ---
# Comma-separated list of allowed origins, or `*` for any (NOT recommended
# in production).
# For local dev:        http://localhost:5173
# For GitHub Pages:    https://hope735.github.io
# For Render frontend: https://your-frontend.onrender.com
CORS_ORIGIN=http://localhost:5173

# --- Auth (JWT) ---
# A long random string. Render can generate one for you via
# `generateValue: true` in render.yaml. If unset, the server falls back to
# DB_PASSWORD (and a dev placeholder in local dev). DO set this in production.
# JWT_SECRET=

# --- Market data proxy (CoinGecko) ---
# Base URL — change to https://pro-api.coingecko.com/api/v3 for Pro tier.
COINGECKO_API=https://api.coingecko.com/api/v3
# Optional API key. Sent as `x-cg-demo-api-key` header. Free tier = blank.
COINGECKO_API_KEY=
